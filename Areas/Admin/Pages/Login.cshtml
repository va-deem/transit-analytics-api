@page "/admin/login"
@model TransitAnalyticsAPI.Areas.Admin.Pages.LoginModel
@{
    ViewData["Title"] = "Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        :root {
            color-scheme: light;
            --bg: #f3efe6;
            --panel: #fffdf7;
            --ink: #1e1b16;
            --accent: #14532d;
            --accent-soft: #d1fae5;
            --border: #d6d0c4;
            --danger: #991b1b;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            background:
                radial-gradient(circle at top, rgba(20, 83, 45, 0.12), transparent 35%),
                linear-gradient(180deg, #f7f2e9 0%, var(--bg) 100%);
            color: var(--ink);
            font-family: Georgia, "Times New Roman", serif;
        }

        main {
            width: min(420px, calc(100vw - 2rem));
            padding: 2rem;
            border: 1px solid var(--border);
            background: var(--panel);
            border-radius: 18px;
            box-shadow: 0 18px 40px rgba(30, 27, 22, 0.12);
        }

        h1 { margin-top: 0; font-size: 2rem; }
        p { line-height: 1.5; }
        label { display: block; margin-bottom: 0.5rem; font-weight: 600; }

        input[type=password] {
            width: 100%;
            padding: 0.8rem 0.9rem;
            border-radius: 10px;
            border: 1px solid var(--border);
            font: inherit;
            margin-bottom: 1rem;
        }

        button {
            width: 100%;
            padding: 0.85rem 1rem;
            border: 0;
            border-radius: 10px;
            background: var(--accent);
            color: white;
            font: inherit;
            cursor: pointer;
        }

        .error {
            margin-bottom: 1rem;
            padding: 0.75rem 0.9rem;
            border-radius: 10px;
            background: #fee2e2;
            color: var(--danger);
        }
    </style>
</head>
<body>
<main>
    <h1>Admin</h1>
    <p>Sign in with the configured administrator password to access operational controls.</p>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="error">@Model.ErrorMessage</div>
    }

    <form method="post">
        <label asp-for="Password">Password</label>
        <input asp-for="Password" type="password" autocomplete="current-password" />
        <button type="submit">Sign In</button>
    </form>
</main>
</body>
</html>
